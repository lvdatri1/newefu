# Eufy Custom Integration - Credentials
#
# Home Assistant auto-configuration:
#   Set these env vars in your HA runtime environment and the integration
#   will configure itself automatically on next startup — no UI steps needed.
#
#   HASSIO/SUPERVISED:  Set via "Configuration -> System -> Environment" or
#                       add to the 'env_vars' section of configuration.yaml.
#   CONTAINER (Docker): Pass with -e EUFY_USERNAME=... -e EUFY_PASSWORD=...
#   CORE:              export the vars before starting Home Assistant.
#
# Testing:
#   Copy this file to .env (gitignored), fill in your values, then:
#     source .env && pytest tests/ -v --run-real
#
# Eufy uses cloud authentication — email, password, and country
# code are needed. No hub IP or port required.
#

# Required: Your Eufy account email
EUFY_USERNAME="your@email.com"

# Required: Your Eufy account password
EUFY_PASSWORD="your_secure_password"

# Required: 2-letter ISO country code for your Eufy account region
# Common values: US, GB, DE, FR, NL, AU, CA, IT, ES, BE, CH, AT, JP
EUFY_COUNTRY="US"

# Optional: Poll interval in seconds (default: 30)
# EUFY_POLL_INTERVAL="30"
